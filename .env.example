# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL / Redis
DB_PASSWORD=replace-with-local-password
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# OA authentication and anti-abuse
AUTH_COOKIE_NAME=oa_session
AUTH_SESSION_TTL=86400
AUTH_COOKIE_SECURE=false
EMAIL_CODE_TTL=300
EMAIL_CODE_COOLDOWN=60
EMAIL_CODE_HOURLY_LIMIT=5
EMAIL_CODE_DAILY_LIMIT=10
EMAIL_CODE_MAX_ATTEMPTS=5
CAPTCHA_TTL=180
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_SECONDS=900

# JWT (use at least 32 random bytes; production rejects the built-in development value)
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes

# OpenAI-compatible model provider
AI_API_KEY=replace-with-provider-key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_UPLOAD_DIRECTORY=./data/chat-attachments

# SMTP mail service (required for real email codes)
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=AI WorkMate
SMTP_FROM_EMAIL=
