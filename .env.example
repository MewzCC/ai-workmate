# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL / Redis
DB_PASSWORD=replace-with-local-password
REDIS_PASSWORD=

# JWT (use at least 32 random bytes; production rejects the built-in development value)
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes

# OpenAI-compatible model provider
AI_API_KEY=replace-with-provider-key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_UPLOAD_DIRECTORY=./data/chat-attachments

# Optional mail service
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
